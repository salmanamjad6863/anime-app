# Base URL where your anime-world Next.js app is running.
# For local development:
#   - If you run the app with `npm run dev` on the same machine as the emulator,
#     http://localhost:3000 is fine for iOS simulator and Android emulator.
#   - If you test on a physical device, change this to your machine's LAN IP,
#     e.g. http://192.168.0.10:3000
EXPO_PUBLIC_ANIMEWORLD_URL=http://localhost:3000

